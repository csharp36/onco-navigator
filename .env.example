# .env.example — Copy this file to .env and fill in real values for local development.
# NEVER commit .env to version control — it is gitignored.
# On AWS, these values come from AWS Secrets Manager (not this file).

# PostgreSQL superuser credentials (used for Docker Compose postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localdev_postgres_root
POSTGRES_DB=postgres

# Application database password (onco_app user on onconavigator database)
APP_DB_PASSWORD=localdev_app_password

# Temporal database password (temporal user on temporal database)
TEMPORAL_DB_PASSWORD=localdev_temporal_password

# Keycloak database password (keycloak user on keycloak database)
KEYCLOAK_DB_PASSWORD=localdev_keycloak_db

# Keycloak admin console password
KEYCLOAK_ADMIN_PASSWORD=localdev_keycloak_admin

# Jasypt master key — used to decrypt ENC(...) values in application-local.yml
# Generate a strong random key: openssl rand -base64 32
JASYPT_MASTER_KEY=localdev_jasypt_master_key_change_me
